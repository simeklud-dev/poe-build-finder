POSTGRES_USER=poe
POSTGRES_PASSWORD=poe
POSTGRES_DB=poe_build_finder

# Used by the FastAPI backend (apps/api) and Alembic
# Poznámka pro hosting (Railway apod.): pokud ti platforma dá DATABASE_URL bez
# "+psycopg" (jen "postgresql://" nebo "postgres://"), backend si ho sám opraví
# (viz app/config.py) — nemusíš tuhle proměnnou ručně upravovat.
DATABASE_URL=postgresql+psycopg://poe:poe@localhost:5432/poe_build_finder

# CORS — čárkou oddělený seznam originů, ze kterých smí frontend volat API.
# Lokálně stačí výchozí hodnota; na hostingu přidej produkční URL frontendu, např.
# CORS_ORIGINS=http://localhost:3000,https://tvuj-frontend.up.railway.app
CORS_ORIGINS=http://localhost:3000

# Admin (pre-moderation) — jediný sdílený admin účet, ZMĚŇ pro cokoliv mimo lokální vývoj
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Sůl pro hashování IP adres v rate limitingu community formuláře — ZMĚŇ na náhodný řetězec
IP_HASH_SALT=change-this-to-a-random-string
SUBMISSION_RATE_LIMIT_PER_HOUR=5

# Reddit konektor (krok 4) — vlastní "script" app na https://www.reddit.com/prefs/apps,
# žádné uživatelské jméno/heslo netřeba. Bez těchto proměnných crawler odmítne spustit.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=poe-build-finder/0.1 (crawler)

# YouTube Data API v3 konektor (krok 5) — API klíč z Google Cloud Console, žádné
# OAuth přihlášení netřeba. Bez něj crawler odmítne spustit.
YOUTUBE_API_KEY=

# Uživatelské účty (post-MVP) — ZMĚŇ na náhodný řetězec (32+ bajtů) pro cokoliv
# mimo lokální vývoj, jinak lze podepisovat/falšovat tokeny.
JWT_SECRET=change-this-to-a-random-string-at-least-32-bytes-long
JWT_EXPIRY_DAYS=30
AUTH_RATE_LIMIT_PER_HOUR=10
